<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Rounded background container (mimics the web dashboard styling) -->
    <path
        android:pathData="M0,20 C0,9 9,0 20,0 h60 C91,0 100,9 100,20 v60 C100,91 91,100 80,100 h-60 C9,100 0,91 0,80 z"
        android:fillColor="#060810" />

    <!-- Outer celestial guideline ring (thin dash) -->
    <path
        android:pathData="M8,50 a42,42 0 1,0 84,0 a42,42 0 1,0 -84,0"
        android:strokeColor="#40D4AF37"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"/>

    <!-- Outer heavy circular boundary -->
    <path
        android:pathData="M8,50 a42,42 0 1,0 84,0 a42,42 0 1,0 -84,0"
        android:strokeColor="#D4AF37"
        android:strokeWidth="2.5"
        android:fillColor="#00000000"/>

    <!-- Rotated alignment diamond (45 degrees rotated square) -->
    <group
        android:rotation="45"
        android:pivotX="50"
        android:pivotY="50">
        <path
            android:pathData="M28,28 h44 v44 h-44 z"
            android:strokeColor="#A6D4AF37"
            android:strokeWidth="1.5"
            android:fillColor="#00000000" />
    </group>

    <!-- Cardinal axis lines (dashed lines representing alignment) -->
    <path
        android:pathData="M50,12 v76 M12,50 h76"
        android:strokeColor="#60D4AF37"
        android:strokeWidth="0.8"
        android:fillColor="#00000000" />

    <!-- Center Bindu (spiritual focus point of Vastu energy) -->
    <path
        android:pathData="M42,50 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0"
        android:fillColor="#FFD700" />

</vector>
