<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Camera Viewfinder -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Visual overlays for guidance -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/gradient_top_shadow"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/gradient_bottom_shadow"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Target Direction Guideline Banner -->
    <TextView
        android:id="@+id/tvGuideHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="1/4: Face NORTH Wall"
        android:textColor="@color/gold_bright"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp"
        android:paddingHorizontal="20dp" />

    <TextView
        android:id="@+id/tvGuideDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Stand in the center of the room. Rotate until your compass shows North, then photograph the wall in front of you."
        android:textColor="@color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:shadowColor="#E6000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3"
        app:layout_constraintTop_toBottomOf="@id/tvGuideHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="30dp" />

    <!-- Active In-App Compass widget -->
    <LinearLayout
        android:id="@+id/layoutCompass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_spinner_dark"
        android:backgroundTint="#CC0E1123"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvGuideDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">

        <TextView
            android:id="@+id/tvCompassAzimuth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0°"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCompassDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" N"
            android:textColor="@color/gold"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- Capture Trigger Button -->
    <ImageButton
        android:id="@+id/btnCapture"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_capture_button"
        android:scaleType="fitCenter"
        android:contentDescription="Capture Photo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp" />

    <!-- Back / Cancel button -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Cancel"
        android:textColor="@color/white"
        android:backgroundTint="@color/status_critical"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="30dp" />

    <!-- Choose from Gallery button -->
    <Button
        android:id="@+id/btnGallery"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Gallery"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="30dp" />

    <!-- Loading State Dialog overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim_heavy"
        android:visibility="gone"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressLoading"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:indeterminateTint="@color/gold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvLoadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyzing room layout alignment..."
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/progressLoading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvLoadingSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sending request to VastuVision AI..."
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvLoadingStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
